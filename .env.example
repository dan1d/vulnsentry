## AutomaticPatch env example (for local dev / self-managed deploys)
## Copy this to .env.local and fill in your values.
##
## dotenv-rails loading order (development/test only):
##   1. .env                 - Shared defaults (committed to repo)
##   2. .env.local           - Local overrides (gitignored)
##   3. .env.development     - Development-specific (committed)
##   4. .env.development.local - Local dev overrides (gitignored)
##   5. .env.test.local      - Local test overrides (gitignored)
##
## For production, use your deployment platform's env var management.

# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGSSLMODE=disable

# Database names (defaults work for local dev)
PRIMARY_DB_NAME=automatic_patch_development
CACHE_DB_NAME=automatic_patch_development_cache
QUEUE_DB_NAME=automatic_patch_development_queue
CABLE_DB_NAME=automatic_patch_development_cable

# GitHub CLI auth (required for GHSA ingestion, PR sync, and opening PRs)
GH_TOKEN=ghp_your_token_here

# SSH for pushing branches to the fork (git)
# Ensure your runtime has an SSH key that can push to your fork.
# Typically you mount ~/.ssh into the container, or provide SSH agent forwarding.
#
# Optional: force a specific key / disable host key prompts:
# GIT_SSH_COMMAND=ssh -i /path/to/id_ed25519 -o StrictHostKeyChecking=accept-new

# DeepSeek AI (optional but recommended for advanced features)
DEEPSEEK_API_KEY=
ENABLE_DEEPSEEK_RUBYLANG_FALLBACK=false
ENABLE_DEEPSEEK_BUNDLED_GEMS_ASSIST=false

