## AutomaticPatch production environment settings
## Copy this to .env.production (or set these as environment variables in your deployment)
## NOTE: dotenv is NOT loaded in production by default - use your deployment platform's
##       environment variable management (Kamal secrets, Docker env, Heroku config, etc.)

# PostgreSQL
PGHOST=your-db-host.example.com
PGPORT=5432
PGUSER=automatic_patch
PGPASSWORD=your_secure_password
PGSSLMODE=require

# Database names (customize if needed)
PRIMARY_DB_NAME=automatic_patch_production
CACHE_DB_NAME=automatic_patch_production_cache
QUEUE_DB_NAME=automatic_patch_production_queue
CABLE_DB_NAME=automatic_patch_production_cable

# GitHub CLI auth (required for GHSA ingestion, PR sync, and opening PRs)
GH_TOKEN=ghp_your_production_token

# DeepSeek AI (optional but recommended)
DEEPSEEK_API_KEY=sk-your_deepseek_key
ENABLE_DEEPSEEK_RUBYLANG_FALLBACK=true
ENABLE_DEEPSEEK_BUNDLED_GEMS_ASSIST=true

# Rails
RAILS_ENV=production
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_SERVE_STATIC_FILES=true

# Kamal Registry (for Docker deployments)
# KAMAL_REGISTRY_PASSWORD=your_registry_token
