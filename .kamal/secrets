# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Source .env.production if it exists (for local deploys)
# shellcheck disable=SC1091
test -f .env.production && { set -a; . .env.production; set +a; }

# Improve security by using a password manager. Never check config/master.key into git!
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || echo "$RAILS_MASTER_KEY")

# Docker Hub (use an access token) - must be set in environment before running kamal
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# GitHub CLI (required) - must be set in environment before running kamal
GH_TOKEN=$GH_TOKEN

# Postgres (required) - must be set in environment before running kamal
PGPASSWORD=$PGPASSWORD

# AI (optional)
DEEPSEEK_API_KEY=$DEEPSEEK_API_KEY
ENABLE_DEEPSEEK_BUNDLED_GEMS_ASSISTANT=true
