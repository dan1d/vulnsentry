      </div>
      
      <div class="column is-one-third">
        <div class="box is-compact has-text-centered">
          <p class="heading">Background Jobs</p>
          <p class="title is-5 has-text-ruby">Solid Queue</p>
          <p class="is-size-7">Rails 8 default job backend</p>
        </div>
      </div>
      
      <div class="column is-one-third">
        <div class="box is-compact has-text-centered">
          <p class="heading">AI/LLM</p>
          <p class="title is-5 has-text-ruby">DeepSeek</p>
          <p class="is-size-7">deepseek-chat model (temp: 0.1)</p>
        </div>
      </div>
      
      <div class="column is-one-third">
        <div class="box is-compact has-text-centered">
          <p class="heading">GitHub Integration</p>
