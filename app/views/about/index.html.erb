    <h2 class="title is-3 mb-4">Tech Stack & Tools</h2>
    
    <div class="columns is-multiline">
      <div class="column is-one-third">
        <div class="box is-compact has-text-centered">
          <p class="heading">Backend Framework</p>
          <p class="title is-5 has-text-ruby">Rails 8</p>
          <p class="is-size-7">Ruby 3.4.7</p>
