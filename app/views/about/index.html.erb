<% content_for :title, "About - VulnSentry" %>

<div class="content">
  <!-- Hero Section -->
  <div class="box has-text-centered mb-6">
    <h1 class="title is-2 mb-3">
      <span class="has-text-ruby">VulnSentry</span>
    </h1>
    <p class="subtitle is-4 mb-4">
      Automated vulnerability detection with human-gated PR creation for Ruby bundled gems
    </p>
    <p class="has-text-grey mb-5">
      A Rails 8 application that monitors Ruby's bundled gems, correlates vulnerability data from multiple sources,
      and produces human-reviewable security patches with LLM-assisted decision making.
    </p>
    
    <!-- Stats Row -->
    <div class="columns is-mobile is-multiline">
      <div class="column is-half-mobile is-one-quarter-tablet">
        <div class="box is-compact">
          <p class="heading">Pull Requests</p>
          <p class="title is-4 has-text-ruby"><%= @total_prs %></p>
        </div>
      </div>
      <div class="column is-half-mobile is-one-quarter-tablet">
        <div class="box is-compact">
          <p class="heading">Vulnerabilities Tracked</p>
          <p class="title is-4 has-text-ruby"><%= @total_advisories %></p>
        </div>
      </div>
      <div class="column is-half-mobile is-one-quarter-tablet">
        <div class="box is-compact">
          <p class="heading">Branches Monitored</p>
          <p class="title is-4 has-text-ruby"><%= @branch_targets %></p>
        </div>
      </div>
      <div class="column is-half-mobile is-one-quarter-tablet">
        <div class="box is-compact">
          <p class="heading">LLM-Assisted</p>
          <p class="title is-4 has-text-ruby"><%= @llm_assisted_bundles %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Problem & Solution -->
  <div class="box mb-6">
    <h2 class="title is-3 mb-4">Problem & Solution</h2>
    
    <div class="columns">
      <div class="column">
        <h3 class="title is-5 has-text-ruby">The Challenge</h3>
        <p class="mb-3">
          Ruby's standard library includes bundled gems that ship with each Ruby release. When vulnerabilities
          are discovered in these gems, they need to be patched quickly to protect the entire Ruby ecosystem.
        </p>
        <p>
          Manually tracking vulnerabilities across multiple sources (GHSA, OSV, ruby-lang announcements),
          determining compatible versions, and creating properly formatted PRs is time-consuming and error-prone.
        </p>
      </div>
      
      <div class="column">
        <h3 class="title is-5 has-text-ruby">The Solution</h3>
        <p class="mb-3">
          VulnSentry automates vulnerability detection and PR preparation while keeping humans in control.
          It monitors multiple Ruby branches, ingests security advisories, and generates minimal, validated patches.
        </p>
        <p>
          The system uses LLM assistance for complex decisions but validates all outputs.
          PR creation requires explicit human approval, ensuring safety and accountability.
        </p>
      </div>
    </div>

    <div class="mt-5">
      <h3 class="title is-5 has-text-ruby mb-3">Safety-First Design</h3>
      <div class="columns is-multiline">
        <div class="column is-half">
          <div class="notification is-dark">
            <strong>Fail Closed:</strong> When parsing or validation is ambiguous, the system blocks the candidate instead of guessing.
          </div>
        </div>
        <div class="column is-half">
          <div class="notification is-dark">
            <strong>Minimal Diffs:</strong> PRs are limited to single-line changes in <code>gems/bundled_gems</code>.
          </div>
        </div>
        <div class="column is-half">
          <div class="notification is-dark">
            <strong>Human-Gated:</strong> All PRs require explicit approval before creation.
          </div>
        </div>
        <div class="column is-half">
          <div class="notification is-dark">
            <strong>Rate Limited:</strong> Cooldowns and caps prevent accidental spam.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- System Architecture -->
  <div class="box mb-6">
    <h2 class="title is-3 mb-4">System Architecture</h2>
    
    <p class="mb-4">
      VulnSentry orchestrates a complete workflow from vulnerability detection to PR creation and synchronization.
      Each step is designed to be resumable and observable through the admin dashboard.
    </p>

    <div class="mb-5">
      <h3 class="title is-5 mb-3">End-to-End Workflow</h3>
      
      <pre class="mermaid">
graph TB
    subgraph sources [Vulnerability Sources]
        GHSA[GHSA API]
        OSV[OSV API]
        RubyLang[ruby-lang RSS]
    end
    
    subgraph ingestion [Ingestion Layer]
        GhsaIngest[GHSA Ingestor]
        OsvIngest[OSV Ingestor]
        Advisory[(Advisory Table)]
    end
    
    subgraph evaluation [Evaluation Engine]
        BranchRefresh[Branch Target Refresh]
        BundledFetch[Fetch bundled_gems]
        AdvisoryChain[Advisory Chain]
        BundleBuilder[Patch Bundle Builder]
    end
    
    subgraph ai [AI Decision Layer]
        VersionResolver[Version Resolver]
        CrossCheck[Maintenance Cross-Check]
        AdvisoryAnalyzer[Advisory Analyzer]
    end
    
    subgraph review [Human Review]
        PatchBundle[(Patch Bundle)]
        AdminUI[Admin Dashboard]
        Approval{Human Approval}
    end
    
    subgraph pr [PR Management]
        CreatePR[Create PR Job]
        PushFork[Push to Fork]
        GHCreate[gh pr create]
        SyncPR[Sync PR Status]
    end
    
    GHSA --> GhsaIngest
    OSV --> OsvIngest
    RubyLang --> GhsaIngest
    RubyLang --> OsvIngest
    
    GhsaIngest --> Advisory
    OsvIngest --> Advisory
    
    BranchRefresh --> CrossCheck
    BranchRefresh --> BundledFetch
    BundledFetch --> AdvisoryChain
    Advisory --> AdvisoryChain
    AdvisoryChain --> BundleBuilder
    
    BundleBuilder --> VersionResolver
    BundleBuilder --> PatchBundle
    
    PatchBundle --> AdminUI
    AdminUI --> Approval
    Approval -->|Approved| CreatePR
    Approval -->|Rejected| PatchBundle
    
    CreatePR --> PushFork
    PushFork --> GHCreate
    GHCreate --> SyncPR
    SyncPR -->|Continuous| AdminUI
      </pre>
    </div>

    <div class="columns is-multiline">
      <div class="column is-half">
        <h4 class="title is-6 has-text-ruby">Key Components</h4>
        <ul>
          <li><strong>Advisory Ingestion:</strong> Multi-source vulnerability data (GHSA + OSV + ruby-lang)</li>
          <li><strong>Branch Evaluation:</strong> Monitors all active Ruby maintenance branches</li>
          <li><strong>Patch Bundle Builder:</strong> Groups related advisories and resolves target versions</li>
          <li><strong>Rate Limiter:</strong> Enforces per-gem, per-branch, and global caps</li>
        </ul>
      </div>
      <div class="column is-half">
        <h4 class="title is-6 has-text-ruby">Background Jobs</h4>
        <ul>
          <li><code>EvaluateOsvVulnerabilitiesJob</code>: Daily evaluation of all branches</li>
          <li><code>CreatePatchBundlePrJob</code>: PR creation after approval</li>
          <li><code>SyncPullRequestsJob</code>: Continuous PR status sync (every 5 min)</li>
          <li><code>ReevaluateAwaitingFixJob</code>: Re-check blocked candidates</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- LLM Integration -->
  <div class="box mb-6">
    <h2 class="title is-3 mb-4">LLM Integration & AI Usage</h2>
    
    <p class="mb-4">
      VulnSentry uses <strong class="has-text-ruby">DeepSeek</strong> for intelligent decision-making in complex scenarios.
      The AI is never authoritative—all outputs are validated, and the system fails closed on ambiguity.
    </p>

    <div class="notification is-dark mb-4">
      <p class="has-text-weight-semibold mb-2">Safety Philosophy: "Never Authoritative, Always Validated"</p>
      <p>
        LLM recommendations are treated as suggestions that must pass strict validation. If validation fails,
        the system falls back to safe defaults or marks the candidate for human review.
      </p>
    </div>

    <h3 class="title is-5 mb-3">AI Services</h3>
    
    <div class="columns is-multiline">
      <div class="column is-half">
        <div class="box is-compact">
          <h4 class="title is-6 has-text-ruby">PatchVersionResolver</h4>
          <p class="heading mb-2">app/services/ai/patch_version_resolver.rb</p>
          <p class="mb-2">
            <strong>Purpose:</strong> Determines the minimum gem version that fixes all listed security advisories when there are conflicting requirements.
          </p>
          <p class="is-size-7 has-text-grey">
            Example: Advisory A suggests 3.2.7, Advisory B suggests 3.3.0 → LLM analyzes and recommends 3.3.0 with reasoning.
          </p>
        </div>
      </div>

      <div class="column is-half">
        <div class="box is-compact">
          <h4 class="title is-6 has-text-ruby">AdvisoryAnalyzer</h4>
          <p class="heading mb-2">app/services/ai/advisory_analyzer.rb</p>
          <p class="mb-2">
            <strong>Purpose:</strong> Prioritizes security advisories by risk level, exploitability, and severity.
          </p>
          <p class="is-size-7 has-text-grey">
            Returns risk scores (1-10), severity assessment, and recommendations for prioritization.
          </p>
        </div>
      </div>

      <div class="column is-half">
        <div class="box is-compact">
          <h4 class="title is-6 has-text-ruby">MaintenanceBranchesCrossCheck</h4>
          <p class="heading mb-2">app/services/ai/maintenance_branches_cross_check.rb</p>
          <p class="mb-2">
            <strong>Purpose:</strong> Cross-checks deterministic parsing of Ruby maintenance branches HTML.
          </p>
          <p class="is-size-7 has-text-grey">
            Validates parser results; raises error on mismatch to fail closed.
          </p>
        </div>
      </div>

      <div class="column is-half">
        <div class="box is-compact">
          <h4 class="title is-6 has-text-ruby">BundledGemsBumpAssistant</h4>
          <p class="heading mb-2">app/services/ai/bundled_gems_bump_assistant.rb</p>
          <p class="mb-2">
            <strong>Purpose:</strong> Fallback for editing <code>gems/bundled_gems</code> when deterministic parsing fails.
          </p>
          <p class="is-size-7 has-text-grey">
            Validates that exactly one line changed and matches expected format.
          </p>
        </div>
      </div>

      <div class="column">
        <div class="box is-compact">
          <h4 class="title is-6 has-text-ruby">SecurityAdvisoryResolver (AI Fallback)</h4>
          <p class="heading mb-2">app/services/ruby_lang/security_advisory_resolver.rb</p>
          <p class="mb-2">
            <strong>Purpose:</strong> Extracts fixed version from ruby-lang security announcement pages when deterministic HTML parsing fails.
          </p>
          <p class="is-size-7 has-text-grey">
            Only enabled with <code>ENABLE_DEEPSEEK_RUBYLANG_FALLBACK=true</code>.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-4">
      <h3 class="title is-5 mb-3">LLM Integration Points</h3>
      
      <pre class="mermaid">
graph LR
    subgraph workflow [Workflow Steps]
        Fetch[Fetch Advisories]
        Build[Build Patch Bundle]
        Validate[Validate Diff]
        Review[Human Review]
    end
    
    subgraph llm [LLM Services]
        Analyzer[Advisory Analyzer]
        Resolver[Version Resolver]
        Assistant[Bump Assistant]
    end
    
    Fetch -->|Multiple Advisories| Analyzer
    Analyzer -->|Risk Scores| Build
    Build -->|Conflicting Versions| Resolver
    Resolver -->|Recommended Version| Validate
    Validate -->|Parse Failure| Assistant
    Assistant -->|Validated Diff| Review
    
    style Analyzer fill:#CC342D20
    style Resolver fill:#CC342D20
    style Assistant fill:#CC342D20
      </pre>
    </div>
  </div>

  <!-- Code Organization -->
  <div class="box mb-6">
    <h2 class="title is-3 mb-4">Code Organization</h2>
    
    <p class="mb-4">
      Built with <strong>Rails 8</strong> and modern Ruby patterns, emphasizing service-oriented architecture,
      clear domain boundaries, and comprehensive background job orchestration.
    </p>

    <div class="columns">
      <div class="column is-half">
        <h3 class="title is-5 has-text-ruby mb-3">Domain Models</h3>
        <div class="content">
          <ul>
            <li>
              <strong>Advisory:</strong> Normalized vulnerability records from GHSA/OSV/ruby-lang
              <br><span class="is-size-7 has-text-grey">Fields: gem_name, cve, fingerprint, fixed_version, severity</span>
            </li>
            <li>
              <strong>PatchBundle:</strong> Primary work unit grouping multiple advisories
              <br><span class="is-size-7 has-text-grey">States: awaiting_fix → needs_review → ready_for_review → approved → submitted</span>
            </li>
            <li>
              <strong>BranchTarget:</strong> Ruby branches to evaluate (ruby_3_3, master, etc.)
              <br><span class="is-size-7 has-text-grey">Tracks maintenance_status and enabled state</span>
            </li>
            <li>
              <strong>PullRequest:</strong> Local record of GitHub PRs with status sync
              <br><span class="is-size-7 has-text-grey">Includes comments_snapshot for maintainer feedback</span>
            </li>
            <li>
              <strong>BotConfig:</strong> Singleton for rate limits and safety settings
            </li>
            <li>
              <strong>SystemEvent:</strong> Append-only audit log for troubleshooting
            </li>
          </ul>
        </div>
      </div>

      <div class="column is-half">
        <h3 class="title is-5 has-text-ruby mb-3">Service Layer</h3>
        <div class="content">
          <p class="mb-2"><strong>Evaluation Services</strong> (<code>app/services/evaluation/</code>):</p>
          <ul class="mb-3">
            <li><code>BundledGemsVulnerabilityEvaluator</code>: Main orchestrator</li>
            <li><code>PatchBundleBuilder</code>: Core candidate builder with LLM integration</li>
            <li><code>BundledGemsAdvisoryChain</code>: Multi-source advisory lookup</li>
          </ul>

          <p class="mb-2"><strong>GitHub Integration</strong> (<code>app/services/github/</code>):</p>
          <ul class="mb-3">
            <li><code>RubyCorePrCreator</code>: Creates PRs via gh CLI</li>
            <li><code>PullRequestStatusFetcher</code>: Syncs PR metadata</li>
            <li><code>GhCli</code>: Wrapper around GitHub CLI</li>
          </ul>

          <p class="mb-2"><strong>Ruby Core Integration</strong> (<code>app/services/ruby_core/</code>):</p>
          <ul>
            <li><code>BundledGemsFetcher</code>: Fetches gems/bundled_gems</li>
            <li><code>BundledGemsBumper</code>: Generates version bump diffs</li>
            <li><code>DiffValidator</code>: Validates single-line changes</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-4">
      <h3 class="title is-5 has-text-ruby mb-3">Service Architecture</h3>
      
      <pre class="mermaid">
graph TB
    subgraph jobs [Background Jobs]
        EvalJob[EvaluateOsvVulnerabilitiesJob]
        CreateJob[CreatePatchBundlePrJob]
        SyncJob[SyncPullRequestsJob]
        ReevalJob[ReevaluateAwaitingFixJob]
    end
    
    subgraph evaluation [Evaluation Services]
        Evaluator[BundledGemsVulnerabilityEvaluator]
        Builder[PatchBundleBuilder]
        Chain[BundledGemsAdvisoryChain]
    end
    
    subgraph github [GitHub Services]
        Creator[RubyCorePrCreator]
        Fetcher[PullRequestStatusFetcher]
        CLI[GhCli]
    end
    
    subgraph models [Domain Models]
        Advisory[(Advisory)]
        Bundle[(PatchBundle)]
        PR[(PullRequest)]
    end
    
    EvalJob --> Evaluator
    Evaluator --> Chain
    Chain --> Advisory
    Evaluator --> Builder
    Builder --> Bundle
    
    CreateJob --> Creator
    Creator --> CLI
    Creator --> PR
    
    SyncJob --> Fetcher
    Fetcher --> CLI
    Fetcher --> PR
    
    ReevalJob --> Builder
      </pre>
    </div>
  </div>

  <!-- Tech Stack -->
