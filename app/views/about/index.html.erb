      <div class="column is-one-third">
        <div class="box is-compact has-text-centered">
          <p class="heading">Testing</p>
          <p class="title is-5 has-text-ruby">RSpec</p>
          <p class="is-size-7">FactoryBot + comprehensive specs</p>
        </div>
      </div>
      
      <div class="column is-one-third">
        <div class="box is-compact has-text-centered">
          <p class="heading">External APIs</p>
          <p class="title is-5 has-text-ruby">GHSA + OSV</p>
          <p class="is-size-7">Multi-source vulnerability data</p>
