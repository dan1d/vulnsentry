<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container is-max-desktop">
    <%= render "shared/page_header",
      title: "Advisory",
      subtitle: @advisory.fingerprint,
      back_path: admin_advisories_path %>

    <div class="content is-small mb-5">
      <p>
        gem: <span class="is-family-monospace"><%= @advisory.gem_name %></span>
        · source: <span class="is-family-monospace"><%= @advisory.source %></span>
        · cve: <span class="is-family-monospace"><%= @advisory.cve.presence || "-" %></span>
      </p>
    </div>

    <%= render "shared/box_section", title: "Links" do %>
      <% if (url = safe_http_url(@advisory.advisory_url)) %>
        <p><%= link_to url, url, target: "_blank", rel: "noopener", class: "has-text-link" %></p>
      <% else %>
        <p class="has-text-grey">(no advisory URL recorded)</p>
      <% end %>
    <% end %>

    <%= render "shared/box_section", title: "Raw payload" do %>
      <%= render "shared/code_block", content: JSON.pretty_generate(@advisory.raw || {}) %>
    <% end %>
  </div>
</section>
