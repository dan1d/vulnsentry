<%= render "admin/shared/nav" %>

<div class="mx-auto max-w-6xl px-4 py-6 space-y-4">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Branch targets</h1>
      <p class="text-sm text-gray-600">Enable/disable supported branches.</p>
    </div>
  </div>

  <div class="rounded border bg-white overflow-hidden">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 text-gray-700">
        <tr>
          <th class="px-4 py-2 text-left">Branch</th>
          <th class="px-4 py-2 text-left">Status</th>
          <th class="px-4 py-2 text-left">Enabled</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @branch_targets.each do |bt| %>
          <tr>
            <td class="px-4 py-2 font-mono"><%= bt.name %></td>
            <td class="px-4 py-2"><%= bt.maintenance_status %></td>
            <td class="px-4 py-2"><%= bt.enabled? %></td>
            <td class="px-4 py-2 text-right">
              <%= link_to "Edit", edit_admin_branch_target_path(bt), class: "text-blue-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
