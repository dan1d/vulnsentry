<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container">
    <%= render "shared/page_header",
      title: "Candidate bumps",
      subtitle: "Review and approve before creating any PR." %>

    <%= render layout: "shared/filter_form", locals: { url: admin_candidate_bumps_path, clear_path: admin_candidate_bumps_path } do %>
      <%= render "shared/filter_field", label: "State", name: :state, value: params[:state], type: :select, options: CandidateBump::STATES %>
      <%= render "shared/filter_field", label: "Branch", name: :base_branch, value: params[:base_branch], monospace: true %>
      <%= render "shared/filter_field", label: "Gem", name: :gem_name, value: params[:gem_name] %>
    <% end %>

    <div class="box">
      <table class="table is-fullwidth is-hoverable">
        <thead>
          <tr>
            <th>Branch</th>
            <th>Gem</th>
            <th>Bump</th>
            <th>State</th>
            <th>PR</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @candidate_bumps.each do |c| %>
            <tr>
              <td class="is-family-monospace"><%= c.base_branch %></td>
              <td><%= c.gem_name %></td>
              <td class="is-family-monospace"><%= c.current_version %> → <%= c.target_version %></td>
              <td><%= render "shared/status_tag", status: c.state, size: "small" %></td>
              <td>
                <% if c.pull_request.present? %>
                  <% pr = c.pull_request %>
                  <% pr_status_color = case pr.status
                     when "merged" then "success"
                     when "closed" then "danger"
                     else "info"
                     end %>
                  <% if pr.pr_url.present? %>
                    <%= link_to "##{pr.pr_number}", pr.pr_url, target: "_blank", rel: "noopener", class: "tag is-#{pr_status_color}" %>
                  <% else %>
                    <span class="tag is-<%= pr_status_color %>">#<%= pr.pr_number || "pending" %></span>
                  <% end %>
                <% else %>
                  <span class="has-text-grey">—</span>
                <% end %>
              </td>
              <td class="has-text-right">
                <%= link_to "View", admin_candidate_bump_path(c), class: "button is-small is-link is-light" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "shared/pagination", collection: @candidate_bumps %>
  </div>
</section>
