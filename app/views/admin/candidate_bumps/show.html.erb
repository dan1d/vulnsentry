<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container is-max-desktop">
    <%= render "shared/page_header",
      title: "Candidate",
      subtitle: "#{@candidate_bump.base_branch}: #{@candidate_bump.gem_name} #{@candidate_bump.current_version} → #{@candidate_bump.target_version}",
      back_path: admin_candidate_bumps_path %>

    <div class="content is-small mb-5">
      <p>state: <%= render "shared/status_tag", status: @candidate_bump.state %></p>
    </div>

    <% if @candidate_bump.pull_request.present? %>
      <% pr = @candidate_bump.pull_request %>
      <%= render "shared/box_section", title: "Pull Request" do %>
        <div class="content">
          <p>
            <strong>PR #<%= pr.pr_number %></strong>
            <% status_color = case pr.status
               when "merged" then "success"
               when "closed" then "danger"
               else "info"
               end %>
            <span class="tag is-<%= status_color %> ml-2"><%= pr.status %></span>
            <% if pr.review_state.present? %>
              <span class="tag is-light ml-1"><%= pr.review_state %></span>
            <% end %>
          </p>
          <% if pr.pr_url.present? %>
            <p>
              <%= link_to pr.pr_url, pr.pr_url, target: "_blank", rel: "noopener" %>
            </p>
          <% end %>
          <p class="is-size-7 has-text-grey">
            <% if pr.opened_at.present? %>
              Opened: <%= pr.opened_at.strftime("%Y-%m-%d %H:%M UTC") %>
            <% end %>
            <% if pr.merged_at.present? %>
              <br>Merged: <%= pr.merged_at.strftime("%Y-%m-%d %H:%M UTC") %>
            <% elsif pr.closed_at.present? %>
              <br>Closed: <%= pr.closed_at.strftime("%Y-%m-%d %H:%M UTC") %>
            <% end %>
            <% if pr.last_synced_at.present? %>
              <br>Last synced: <%= pr.last_synced_at.strftime("%Y-%m-%d %H:%M UTC") %>
            <% end %>
          </p>
        </div>
      <% end %>
    <% end %>

    <%= render "shared/box_section", title: "Proposed diff" do %>
      <%= render "shared/code_block",
        content: @candidate_bump.proposed_diff,
        empty_text: "(not generated yet)" %>
    <% end %>

    <%= render "shared/box_section", title: "Actions" do %>
      <div class="buttons">
        <%= button_to "Approve", admin_candidate_bump_path(@candidate_bump), method: :patch, params: { event: "approve" }, class: "button is-dark" %>
        <%= button_to "Reject", admin_candidate_bump_path(@candidate_bump), method: :patch, params: { event: "reject", reason: "rejected_by_admin" }, class: "button is-light" %>

        <% if @candidate_bump.state == "approved" %>
          <%= button_to "Create PR", admin_candidate_bump_path(@candidate_bump), method: :patch, params: { event: "create_pr" }, class: "button is-ruby" %>
          <%= button_to "Create Draft PR", admin_candidate_bump_path(@candidate_bump), method: :patch, params: { event: "create_draft_pr" }, class: "button is-ruby is-outlined" %>
        <% end %>
      </div>

      <p class="is-size-7 has-text-grey">
        Two-click safety: Approve first, then Create PR (or Draft PR).
      </p>
    <% end %>
  </div>
</section>
