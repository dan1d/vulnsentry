<%# Quick actions panel for dashboard
    Local variables:
    - pending_reviews_count: (required) Count of bundles awaiting review
    - ai_recommendations_count: (required) Count of LLM-resolved bundles needing review
%>
<div class="box quick-actions-panel">
  <div class="is-flex is-align-items-center mb-4">
    <span class="icon has-text-ruby mr-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
    </span>
    <p class="has-text-weight-medium">Quick Actions</p>
  </div>

  <div class="buttons quick-action-buttons">
    <!-- Trigger Advisory Sync -->
    <%= button_to admin_trigger_advisory_sync_path,
        method: :post,
        class: "button is-fullwidth is-ruby is-outlined quick-action-btn",
        data: {
          turbo_confirm: "This will trigger a full advisory sync from OSV. Continue?",
          controller: "loading-button",
          action: "click->loading-button#start"
        } do %>
      <span class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/>
        </svg>
      </span>
      <span>Sync Advisories</span>
    <% end %>

    <!-- View Pending Reviews -->
    <%= link_to admin_patch_bundles_path(state: "ready_for_review"), class: "button is-fullwidth is-light quick-action-btn" do %>
      <span class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
      </span>
      <span>Pending Reviews</span>
      <% if pending_reviews_count > 0 %>
        <span class="tag is-warning is-rounded ml-2"><%= pending_reviews_count %></span>
      <% end %>
    <% end %>

    <!-- View AI Recommendations -->
    <%= link_to admin_patch_bundles_path(resolution_source: "llm", state: "ready_for_review"), class: "button is-fullwidth is-light quick-action-btn" do %>
      <span class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a4 4 0 0 1 4 4v1a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2V6a4 4 0 0 1 4-4z"/>
          <path d="M9 18h6"/>
          <path d="M10 22h4"/>
        </svg>
      </span>
      <span>AI Recommendations</span>
      <% if ai_recommendations_count > 0 %>
        <span class="tag is-info is-rounded ml-2"><%= ai_recommendations_count %></span>
      <% end %>
    <% end %>

    <!-- Re-evaluate Awaiting Fix -->
    <%= button_to admin_trigger_reevaluation_path,
        method: :post,
        class: "button is-fullwidth is-light quick-action-btn",
        data: {
          turbo_confirm: "This will re-evaluate all bundles awaiting fixes. Continue?",
          controller: "loading-button",
          action: "click->loading-button#start"
        } do %>
      <span class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </span>
      <span>Re-evaluate Awaiting</span>
    <% end %>
  </div>
</div>
