<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container">
    <%= render "shared/page_header",
      title: "Pull requests",
      subtitle: "PRs created by this app (and tracked in DB)." %>

    <%= render layout: "shared/filter_form", locals: { url: admin_pull_requests_path, clear_path: admin_pull_requests_path } do %>
      <%= render "shared/filter_field", label: "Status", name: :status, value: params[:status], type: :select, options: PullRequest::STATUSES %>
      <%= render "shared/filter_field", label: "Branch", name: :base_branch, value: params[:base_branch], monospace: true %>
      <%= render "shared/filter_field", label: "Upstream repo", name: :upstream_repo, value: params[:upstream_repo], monospace: true %>
    <% end %>

    <div class="box">
      <table class="table is-fullwidth is-hoverable">
        <thead>
          <tr>
            <th>PR</th>
            <th>Branch</th>
            <th>Gem</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @pull_requests.each do |pr| %>
            <tr>
              <td class="is-family-monospace"><%= pr.pr_number || "?" %></td>
              <td class="is-family-monospace"><%= pr.candidate_bump.base_branch %></td>
              <td><%= pr.candidate_bump.gem_name %> <span class="is-family-monospace">→ <%= pr.candidate_bump.target_version %></span></td>
              <td><%= render "shared/status_tag", status: pr.status, size: "small" %></td>
              <td class="has-text-right">
                <%= link_to "View", admin_pull_request_path(pr), class: "button is-small is-link is-light" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "shared/pagination", collection: @pull_requests %>
  </div>
</section>
