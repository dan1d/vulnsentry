<%= render "admin/shared/nav" %>

<div class="mx-auto max-w-4xl px-4 py-6 space-y-6">
  <div class="flex items-start justify-between gap-6">
    <div>
      <h1 class="text-2xl font-semibold">PR <span class="font-mono">#<%= @pull_request.pr_number || "?" %></span></h1>
      <div class="mt-1 text-sm text-gray-600 font-mono">
        <%= @pull_request.candidate_bump.base_branch %>: <%= @pull_request.candidate_bump.gem_name %> → <%= @pull_request.candidate_bump.target_version %>
      </div>
      <div class="mt-1 text-sm text-gray-600">status: <span class="font-mono"><%= @pull_request.status %></span></div>
      <div class="mt-1 text-sm text-gray-600">
        synced: <span class="font-mono"><%= @pull_request.last_synced_at&.iso8601 || "-" %></span>
        · comments: <span class="font-mono"><%= @pull_request.comments_last_synced_at&.iso8601 || "-" %></span>
      </div>
    </div>
    <div class="text-sm">
      <%= link_to "Back", admin_pull_requests_path, class: "rounded border px-3 py-2" %>
    </div>
  </div>

  <div class="rounded border bg-white p-4 space-y-2">
    <div class="text-sm font-medium">Links</div>
    <% if @pull_request.pr_url.present? %>
      <div class="text-sm"><%= link_to @pull_request.pr_url, @pull_request.pr_url, class: "text-blue-600 hover:underline" %></div>
    <% else %>
      <div class="text-sm text-gray-600">(no URL recorded yet)</div>
    <% end %>
  </div>

  <% snapshot = @pull_request.comments_snapshot || {} %>
  <% issue_comments = Array(snapshot["issue_comments"]) %>
  <% reviews = Array(snapshot["reviews"]) %>
  <% review_comments = Array(snapshot["review_comments"]) %>

  <div class="rounded border bg-white p-4 space-y-6">
    <div class="flex items-center justify-between gap-4">
      <div class="text-sm font-medium">Comments snapshot</div>
      <div class="text-xs text-gray-600 font-mono">
        issue: <%= issue_comments.size %> · reviews: <%= reviews.size %> · inline: <%= review_comments.size %>
      </div>
    </div>

    <div class="space-y-3">
      <div class="text-sm font-medium">Issue comments</div>
      <% if issue_comments.empty? %>
        <div class="text-sm text-gray-600">(none)</div>
      <% else %>
        <% issue_comments.last(20).each do |c| %>
          <div class="rounded border p-3 space-y-1">
            <div class="text-xs text-gray-600 font-mono">
              <%= c["created_at"] %> · <%= c["user"] || "?" %>
              <% if c["url"].present? %>
                · <%= link_to "view", c["url"], class: "text-blue-600 hover:underline", target: "_blank", rel: "noopener" %>
              <% end %>
            </div>
            <div class="text-sm whitespace-pre-wrap"><%= truncate(c["body"].to_s, length: 1200) %></div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="space-y-3">
      <div class="text-sm font-medium">Reviews</div>
      <% if reviews.empty? %>
        <div class="text-sm text-gray-600">(none)</div>
      <% else %>
        <% reviews.last(20).each do |r| %>
          <div class="rounded border p-3 space-y-1">
            <div class="text-xs text-gray-600 font-mono">
              <%= r["submitted_at"] %> · <%= r["user"] || "?" %> · <%= r["state"] %>
              <% if r["url"].present? %>
                · <%= link_to "view", r["url"], class: "text-blue-600 hover:underline", target: "_blank", rel: "noopener" %>
              <% end %>
            </div>
            <% if r["body"].present? %>
              <div class="text-sm whitespace-pre-wrap"><%= truncate(r["body"].to_s, length: 1200) %></div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="space-y-3">
      <div class="text-sm font-medium">Inline review comments</div>
      <% if review_comments.empty? %>
        <div class="text-sm text-gray-600">(none)</div>
      <% else %>
        <% review_comments.last(20).each do |c| %>
          <div class="rounded border p-3 space-y-1">
            <div class="text-xs text-gray-600 font-mono">
              <%= c["created_at"] %> · <%= c["user"] || "?" %> · <%= c["path"] %>:<%= c["line"] || c["position"] %>
              <% if c["url"].present? %>
                · <%= link_to "view", c["url"], class: "text-blue-600 hover:underline", target: "_blank", rel: "noopener" %>
              <% end %>
            </div>
            <div class="text-sm whitespace-pre-wrap"><%= truncate(c["body"].to_s, length: 1200) %></div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
