<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container is-max-desktop">
    <%= render "shared/page_header",
      title: "Edit settings",
      subtitle: "Changes apply immediately.",
      back_path: admin_settings_path %>

    <div class="box">
      <%= form_with model: @config, url: admin_settings_path, method: :patch do |f| %>
        <div class="field">
          <label class="checkbox">
            <%= f.check_box :require_human_approval %>
            Require human approval
          </label>
        </div>

        <div class="field">
          <label class="checkbox">
            <%= f.check_box :emergency_stop %>
            Emergency stop
          </label>
        </div>

        <div class="field">
          <label class="checkbox">
            <%= f.check_box :allow_draft_pr %>
            Allow draft PR
          </label>
        </div>

        <p class="has-text-weight-medium mt-5 mb-3">Caps</p>

        <div class="columns">
          <div class="column">
            <div class="field">
              <%= f.label :global_daily_cap, class: "label" %>
              <div class="control">
                <%= f.number_field :global_daily_cap, class: "input" %>
              </div>
            </div>
          </div>
          <div class="column">
            <div class="field">
              <%= f.label :global_hourly_cap, class: "label" %>
              <div class="control">
                <%= f.number_field :global_hourly_cap, class: "input" %>
              </div>
            </div>
          </div>
        </div>

        <div class="columns">
          <div class="column">
            <div class="field">
              <%= f.label :per_branch_daily_cap, class: "label" %>
              <div class="control">
                <%= f.number_field :per_branch_daily_cap, class: "input" %>
              </div>
            </div>
          </div>
          <div class="column">
            <div class="field">
              <%= f.label :per_gem_daily_cap, class: "label" %>
              <div class="control">
                <%= f.number_field :per_gem_daily_cap, class: "input" %>
              </div>
            </div>
          </div>
        </div>

        <div class="columns">
          <div class="column is-half">
            <div class="field">
              <%= f.label :rejection_cooldown_hours, class: "label" %>
              <div class="control">
                <%= f.number_field :rejection_cooldown_hours, class: "input" %>
              </div>
            </div>
          </div>
        </div>

        <p class="has-text-weight-medium mt-5 mb-3">GitHub</p>

        <div class="field">
          <%= f.label :fork_repo, class: "label" %>
          <div class="control">
            <%= f.text_field :fork_repo, class: "input is-family-monospace" %>
          </div>
        </div>

        <div class="field">
          <%= f.label :upstream_repo, class: "label" %>
          <div class="control">
            <%= f.text_field :upstream_repo, class: "input is-family-monospace" %>
          </div>
        </div>

        <div class="field">
          <%= f.label :fork_git_url, class: "label" %>
          <div class="control">
            <%= f.text_field :fork_git_url, class: "input is-family-monospace" %>
          </div>
        </div>

        <div class="field is-grouped mt-5">
          <%= f.submit "Save", class: "button is-ruby" %>
          <%= link_to "Cancel", admin_settings_path, class: "button is-light" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
