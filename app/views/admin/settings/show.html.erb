<%= render "admin/shared/nav" %>

<div class="mx-auto max-w-4xl px-4 py-6 space-y-4">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Settings</h1>
      <p class="text-sm text-gray-600">Safety and rate limits.</p>
    </div>
    <div>
      <%= link_to "Edit", edit_admin_settings_path, class: "rounded border px-4 py-2 text-sm" %>
    </div>
  </div>

  <div class="rounded border bg-white p-4 space-y-2 text-sm">
    <div><span class="font-medium">require_human_approval</span>: <%= @config.require_human_approval? %></div>
    <div><span class="font-medium">emergency_stop</span>: <%= @config.emergency_stop? %></div>
    <div><span class="font-medium">allow_draft_pr</span>: <%= @config.allow_draft_pr? %></div>
    <div class="pt-2 font-medium">Caps</div>
    <div>global_daily_cap: <%= @config.global_daily_cap %></div>
    <div>global_hourly_cap: <%= @config.global_hourly_cap %></div>
    <div>per_branch_daily_cap: <%= @config.per_branch_daily_cap %></div>
    <div>per_gem_daily_cap: <%= @config.per_gem_daily_cap %></div>
    <div>rejection_cooldown_hours: <%= @config.rejection_cooldown_hours %></div>
    <div class="pt-2 font-medium">GitHub</div>
    <div>fork_repo: <span class="font-mono"><%= @config.fork_repo %></span></div>
    <div>upstream_repo: <span class="font-mono"><%= @config.upstream_repo %></span></div>
    <div>fork_git_url: <span class="font-mono"><%= @config.fork_git_url %></span></div>
  </div>
</div>
