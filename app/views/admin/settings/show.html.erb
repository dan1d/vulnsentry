<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container is-max-desktop">
    <%= render "shared/page_header",
      title: "Settings",
      subtitle: "Safety and rate limits.",
      actions: link_to("Edit", edit_admin_settings_path, class: "button is-ruby") %>

    <div class="box content">
      <p><strong>require_human_approval</strong>: <%= render "shared/status_tag", status: @config.require_human_approval?.to_s %></p>
      <p><strong>emergency_stop</strong>: <%= render "shared/status_tag", status: @config.emergency_stop? ? "danger" : "success", text: @config.emergency_stop?.to_s %></p>
      <p><strong>allow_draft_pr</strong>: <%= render "shared/status_tag", status: @config.allow_draft_pr?.to_s %></p>

      <p class="has-text-weight-medium mt-5">Caps</p>
      <p>global_daily_cap: <span class="is-family-monospace"><%= @config.global_daily_cap %></span></p>
      <p>global_hourly_cap: <span class="is-family-monospace"><%= @config.global_hourly_cap %></span></p>
      <p>per_branch_daily_cap: <span class="is-family-monospace"><%= @config.per_branch_daily_cap %></span></p>
      <p>per_gem_daily_cap: <span class="is-family-monospace"><%= @config.per_gem_daily_cap %></span></p>
      <p>rejection_cooldown_hours: <span class="is-family-monospace"><%= @config.rejection_cooldown_hours %></span></p>

      <p class="has-text-weight-medium mt-5">GitHub</p>
      <p>fork_repo: <span class="is-family-monospace"><%= @config.fork_repo %></span></p>
      <p>upstream_repo: <span class="is-family-monospace"><%= @config.upstream_repo %></span></p>
      <p>fork_git_url: <span class="is-family-monospace"><%= @config.fork_git_url %></span></p>

      <% deepseek_client = Ai::DeepseekClient.new %>
      <% bump_assistant = Ai::BundledGemsBumpAssistant.new %>
      <p class="has-text-weight-medium mt-5">AI (Deepseek)</p>
      <p>
        <strong>API configured</strong>:
        <%= render "shared/status_tag", status: deepseek_client.enabled?.to_s %>
        <span class="is-size-7 has-text-grey ml-2">(DEEPSEEK_API_KEY)</span>
      </p>
      <p>
        <strong>Branch cross-check</strong>:
        <%= render "shared/status_tag", status: deepseek_client.enabled?.to_s %>
        <span class="is-size-7 has-text-grey ml-2">Validates branch parsing against LLM</span>
      </p>
      <p>
        <strong>Bundled gems assistant</strong>:
        <%= render "shared/status_tag", status: bump_assistant.enabled?.to_s %>
        <span class="is-size-7 has-text-grey ml-2">(ENABLE_DEEPSEEK_BUNDLED_GEMS_ASSIST)</span>
      </p>
    </div>
  </div>
</section>
