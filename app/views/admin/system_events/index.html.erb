<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container">
    <%= render "shared/page_header",
      title: "System events",
      subtitle: "Recent app events, warnings, and failures." %>

    <div class="box">
    <%= render layout: "shared/filter_form", locals: { url: admin_system_events_path, clear_path: admin_system_events_path } do %>
      <%= render "shared/filter_field", label: "Search", name: :q, value: params[:q], placeholder: "message or payload...", column_class: "column is-4" %>
      <%= render "shared/filter_field", label: "Kind", name: :kind, value: params[:kind] %>
      <%= render "shared/filter_field", label: "Status", name: :status, value: params[:status] %>
      <%= render "shared/filter_field", label: "Gem", name: :gem_name, value: params[:gem_name] %>
      <%= render "shared/filter_field", label: "Branch", name: :branch, value: params[:branch] %>
      <%= render "shared/filter_field", label: "Occurred after", name: :occurred_after, value: params[:occurred_after], placeholder: "YYYY-MM-DD or ISO" %>
      <%= render "shared/filter_field", label: "Occurred before", name: :occurred_before, value: params[:occurred_before], placeholder: "YYYY-MM-DD or ISO" %>
    <% end %>

      <% if @events.any? %>
        <table class="table is-fullwidth is-hoverable">
          <thead>
            <tr>
              <th>Kind</th>
              <th>Status</th>
              <th>Message</th>
              <th>Time</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @events.each do |ev| %>
              <tr>
                <td class="is-family-monospace"><%= ev.kind %></td>
                <td><%= render "shared/status_tag", status: ev.status, size: "small" %></td>
                <td class="has-text-overflow-ellipsis" style="max-width: 30rem;">
                  <%= truncate(ev.message.to_s, length: 80) %>
                </td>
                <td class="has-text-grey is-size-7"><%= ev.occurred_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td class="has-text-right">
                  <%= link_to "View", admin_system_event_path(ev), class: "button is-small is-link is-light" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <%= render "shared/empty_state", message: "No events yet." %>
      <% end %>
    </div>

    <%= render "shared/pagination", collection: @events %>
  </div>
</section>
