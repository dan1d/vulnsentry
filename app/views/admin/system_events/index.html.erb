<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container">
    <%= render "shared/page_header",
      title: "System events",
      subtitle: "Recent app events, warnings, and failures." %>

    <div class="box">
      <% if @events.any? %>
        <table class="table is-fullwidth is-hoverable">
          <thead>
            <tr>
              <th>Kind</th>
              <th>Status</th>
              <th>Message</th>
              <th>Time</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @events.each do |ev| %>
              <tr>
                <td class="is-family-monospace"><%= ev.kind %></td>
                <td><%= render "shared/status_tag", status: ev.status, size: "small" %></td>
                <td class="has-text-overflow-ellipsis" style="max-width: 30rem;">
                  <%= truncate(ev.message.to_s, length: 80) %>
                </td>
                <td class="has-text-grey is-size-7"><%= ev.occurred_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td class="has-text-right">
                  <%= link_to "View", admin_system_event_path(ev), class: "button is-small is-link is-light" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <%= render "shared/empty_state", message: "No events yet." %>
      <% end %>
    </div>

    <%= render "shared/pagination", collection: @events %>
  </div>
</section>
