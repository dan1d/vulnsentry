<%= render "admin/shared/nav" %>

<section class="section">
  <div class="container">
    <p class="subtitle is-6 mb-2">
      <%= link_to "System events", admin_system_events_path, class: "has-text-grey" %>
    </p>

    <%= render "shared/page_header",
      title: "#{@event.kind}".html_safe,
      actions: render("shared/status_tag", status: @event.status) %>

    <p class="has-text-grey is-size-7 mb-5"><%= @event.occurred_at.strftime("%Y-%m-%d %H:%M:%S %Z") %></p>

    <% if @event.message.present? %>
      <%= render "shared/box_section", title: "Message" do %>
        <%= render "shared/code_block", content: @event.message %>
      <% end %>
    <% end %>

    <%= render "shared/box_section", title: "Payload" do %>
      <%= render "shared/code_block", content: JSON.pretty_generate(@event.payload || {}) %>
    <% end %>

    <% backtrace = @event.payload.dig("exception", "backtrace") || @event.payload.dig(:exception, :backtrace) %>
    <% if backtrace.present? %>
      <%= render "shared/box_section", title: "Stack trace" do %>
        <%= render "shared/code_block", content: Array(backtrace).join("\n") %>
      <% end %>
    <% end %>
  </div>
</section>
