<div class="content">
  <div class="box">
    <%= render "shared/page_header",
      title: "Security PRs",
      subtitle: "This dashboard lists PRs created by this app (tracked in the database)." %>
  </div>

  <% if @pull_requests.any? %>
    <%= render "shared/box_section", title: "Pull requests" do %>
      <% @pull_requests.each_with_index do |pr, index| %>
        <% bump = pr.patch_bundle || pr.candidate_bump %>

        <div class="content">
          <p class="mb-1">
            <span class="is-family-monospace">#<%= pr.pr_number || "?" %></span>
            <%= render "shared/status_tag", status: pr.status, size: "small" %>

            <span class="has-text-grey is-size-7 ml-2">
              created: <span class="is-family-monospace"><%= pr.created_at.strftime("%Y-%m-%d") %></span>
              · merged: <span class="is-family-monospace"><%= pr.merged_at&.strftime("%Y-%m-%d") || "—" %></span>
            </span>
          </p>

          <p class="mb-2">
            <% if bump.present? %>
              <strong class="mr-1">Bump</strong>
              <span class="is-family-monospace"><%= bump.base_branch %></span>:
              <%= bump.gem_name %>
              <% if bump.respond_to?(:bump_display) %>
                <span class="is-family-monospace"><%= bump.bump_display %></span>
              <% else %>
                <span class="is-family-monospace"><%= bump.current_version %> → <%= bump.target_version %></span>
              <% end %>
            <% else %>
              <span class="has-text-grey">(missing bump record)</span>
            <% end %>
          </p>

          <p class="mb-3">
            <strong class="mr-1">PR</strong>
            <% if (url = safe_http_url(pr.pr_url)) %>
              <%= link_to url, url, target: "_blank", rel: "noopener", class: "is-family-monospace" %>
            <% else %>
              <span class="has-text-grey">(no link recorded yet)</span>
            <% end %>
          </p>

          <details>
            <summary class="has-text-link">Proposed diff</summary>
            <div class="mt-2">
              <%= render "shared/code_block",
                content: bump&.proposed_diff,
                empty_text: "(not generated yet)" %>
            </div>
          </details>
        </div>

        <% unless index == @pull_requests.size - 1 %>
          <hr>
        <% end %>
      <% end %>
    <% end %>

    <%= render "shared/pagination", collection: @pull_requests, per_page_options: [5, 10, 25, 50] %>
  <% else %>
    <div class="box">
      <%= render "shared/empty_state",
        message: "No PRs tracked yet. When a PR is created and synced, it will show up here." do %>
        <%= link_to "Open admin dashboard", admin_root_path, class: "button is-ruby" %>
        <%= link_to "View GitHub profile", "https://github.com/dan1d", target: "_blank", rel: "noopener", class: "button is-light" %>
      <% end %>
    </div>
  <% end %>
</div>
