<header class="sticky top-0 z-10 border-b bg-white/90 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <%= image_tag "ruby.svg", alt: "Ruby", class: "h-7 w-7" %>
      <div class="leading-tight">
        <div class="font-semibold text-gray-900">VulnSentry</div>
        <div class="text-xs text-gray-600">Bundled gem security PR helper</div>
      </div>
    </div>

    <nav class="flex items-center gap-3 text-sm">
      <% if admin_signed_in? %>
        <%= link_to "Admin", admin_root_path, class: "rounded px-3 py-2 text-gray-700 hover:bg-gray-100" %>
        <%= button_to "Logout", logout_path, method: :delete, class: "rounded px-3 py-2 text-gray-700 hover:bg-gray-100" %>
      <% else %>
        <%= link_to "Sign in", sign_in_path, class: "rounded px-3 py-2 text-gray-700 hover:bg-gray-100" %>
      <% end %>
      <%= link_to "GitHub (dan1d)", "https://github.com/dan1d", target: "_blank", rel: "noopener", class: "rounded px-3 py-2 text-gray-700 hover:bg-gray-100" %>
      <%= link_to "ruby/ruby", "https://github.com/ruby/ruby", target: "_blank", rel: "noopener", class: "rounded px-3 py-2 text-gray-700 hover:bg-gray-100" %>
      <span class="inline-flex items-center rounded-full bg-[#CC342D]/10 px-3 py-1 text-xs font-medium text-[#CC342D]">
        Ruby red mode
      </span>
    </nav>
  </div>
</header>
