<%# Stat card component for dashboard metrics
    Local variables:
    - label: (required) The stat label
    - value: (required) The stat value
    - link_path: (optional) Path to link to
%>
<div class="box has-text-centered">
  <p class="heading"><%= label %></p>
  <% if local_assigns[:link_path] %>
    <%= link_to value, link_path, class: "title is-3" %>
  <% else %>
    <p class="title is-3"><%= value %></p>
  <% end %>
</div>
